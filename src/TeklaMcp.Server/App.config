<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!-- Tekla.* assemblies are supplied at runtime by TeklaAssemblyResolver (see Program.cs).
         Do NOT redirect Tekla.* to an unreachable version here — that breaks loading on live
         Tekla installs (AssemblyResolve cannot satisfy a 2999.9.9.9 bind with a 2023 DLL). -->
  </runtime>
</configuration>
