<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!--
        Universal-build guarantee (net48): ALWAYS load the Tekla Open API assemblies from the
        installed/running Tekla (TeklaAssemblyResolver), NEVER from the GAC.

        Why: the code compiles against a baseline Tekla API (2021). If a stale copy of that
        exact version sits in the GAC, .NET Framework binds to it silently and the resolver
        never fires — the server then speaks the wrong remoting protocol to the running Tekla
        and every dedicated tool fails (issue #7; reproduced 2026-07-08 on live Tekla 2023 with
        GAC 2021: channel ':2021.0.0.0' vs published pipe ':2023.0.0.0'). Redirecting to a
        version that cannot exist forces the normal bind — including the GAC probe — to fail,
        so resolution always reaches AssemblyResolve, which supplies the running Tekla's DLLs.

        History: cbe716b removed these redirects because the then-LoadFile-based resolver
        re-entered the redirect chain until StackOverflow. The resolver now byte-loads into the
        default context with a preloaded cache and a re-entrancy guard (TeklaAssemblyResolver),
        so the redirected bind is satisfied in one hop; if resolution ever fails anyway, the
        guard turns it into a per-call bind error, not a crash.

        Ops escape hatch: if this ever misbehaves on a machine, delete these dependentAssembly
        blocks from TeklaMcp.Server.exe.config next to the exe (config is read at start).
        The .NET 8 (mock) build ignores this section entirely.
      -->
      <dependentAssembly>
        <assemblyIdentity name="Tekla.Structures" publicKeyToken="2f04dbe497b71114" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-2999.9.9.9" newVersion="2999.9.9.9" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Tekla.Structures.Model" publicKeyToken="2f04dbe497b71114" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-2999.9.9.9" newVersion="2999.9.9.9" />
      </dependentAssembly>
      <!-- Same treatment for the closure assemblies: harmless no-ops when they are not in the
           GAC, but prevent a mixed 2021/2023 load when they are. -->
      <dependentAssembly>
        <assemblyIdentity name="Tekla.Structures.Datatype" publicKeyToken="2f04dbe497b71114" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-2999.9.9.9" newVersion="2999.9.9.9" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Tekla.Structures.Plugins" publicKeyToken="2f04dbe497b71114" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-2999.9.9.9" newVersion="2999.9.9.9" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
