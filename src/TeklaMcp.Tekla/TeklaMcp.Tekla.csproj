<Project Sdk="Microsoft.NET.Sdk">

  <!--
    REAL Tekla Open API implementation. Windows-only.

    Tekla Structures Open API assemblies are Windows-only and target .NET Framework.
    so this project does too. It is referenced by the server ONLY in its net48 build
    (see TeklaMcp.Server.csproj). It will NOT build on macOS — that is expected.

    The Tekla.Structures.* packages are restored from NuGet on the Windows machine.
    The package VERSION must match the installed Tekla Structures.
    Update the versions below if your installed Tekla differs, or switch to local
    <Reference> elements with <HintPath> pointing at the Tekla install \bin folder.
  -->
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <RootNamespace>TeklaMcp.Tekla</RootNamespace>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\TeklaMcp.Core\TeklaMcp.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Tekla 2023 compatibility baseline. -->
    <PackageReference Include="Tekla.Structures" Version="2023.0.0" />
    <PackageReference Include="Tekla.Structures.Model" Version="2023.0.0" />
  </ItemGroup>

</Project>
