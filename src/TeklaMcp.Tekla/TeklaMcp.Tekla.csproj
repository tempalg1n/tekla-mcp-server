<Project Sdk="Microsoft.NET.Sdk">

  <!--
    REAL Tekla Open API implementation. Windows-only.

    Tekla Structures 2026 Open API assemblies target .NET Framework 4.8 / x64,
    so this project does too. It is referenced by the server ONLY in its net48 build
    (see TeklaMcp.Server.csproj). It will NOT build on macOS — that is expected.

    The Tekla.Structures.* packages are restored from NuGet on the Windows machine.
    The package VERSION must match the installed Tekla Structures (2026.0.x here).
    Update the versions below if your installed Tekla differs, or switch to local
    <Reference> elements with <HintPath> pointing at the Tekla install \bin folder.
  -->
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <RootNamespace>TeklaMcp.Tekla</RootNamespace>
    <PlatformTarget>x64</PlatformTarget>
    <!-- Tekla 2026 supports x64 extensions only. -->
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\TeklaMcp.Core\TeklaMcp.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- TODO(windows): verify these versions against the installed Tekla 2026.0.x. -->
    <PackageReference Include="Tekla.Structures" Version="2026.0.3" />
    <PackageReference Include="Tekla.Structures.Model" Version="2026.0.3" />
  </ItemGroup>

</Project>
